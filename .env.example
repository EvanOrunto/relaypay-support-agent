# ============================================================
# RelayPay Voice Support Agent — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# VAPI
VAPI_PUBLIC_KEY=your_vapi_public_key_here
VAPI_ASSISTANT_ID=your_vapi_assistant_id_here
VAPI_PRIVATE_KEY=your_vapi_private_key_here

# n8n
N8N_WEBHOOK_URL=https://cohort2pod3.app.n8n.cloud/webhook/relaypay-support
N8N_WEBHOOK_SECRET=your_shared_webhook_secret_here
N8N_INSTANCE_URL=https://cohort2pod3.app.n8n.cloud/
N8N_API_KEY=your_n8n_api_key_here

# Supabase
SUPABASE_URL=https://lgcokylcrzprpdnndhlk.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Notion
NOTION_TOKEN=your_notion_internal_integration_token_here

# Anthropic (used inside n8n workflow for Claude API calls)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GitHub
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=EvanOrunto/relaypay-support-agent
