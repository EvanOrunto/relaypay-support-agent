    {
      "id": "node-12",
      "name": "Build Response High",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2160,
        340
      ],
      "parameters": {
        "jsCode": "const openaiOutput = $input.first().json;\nconst ctx = $(\"Confidence Evaluator\").item.json;\n// Native OpenAI node returns output[0].content[0].text\nconst text = openaiOutput.output && openaiOutput.output[0] && openaiOutput.output[0].content && openaiOutput.output[0].content[0] && openaiOutput.output[0].content[0].text;\nif (!text) {\n  return [{ json: { session_id: ctx.session_id, customer_id: ctx.customer_id, question: ctx.question, confidence: \"escalated\", keyword_matched: null, response: \"I'm having trouble retrieving that information right now. Let me connect you with our support team.\", escalated: true, escalation_reason: \"openai_api_error\", escalation_notified: false, } }];\n}\nreturn [{ json: { session_id: ctx.session_id, customer_id: ctx.customer_id, question: ctx.question, confidence: \"high\", keyword_matched: null, response: text, escalated: false, escalation_reason: null, escalation_notified: false, } }];"
      }
