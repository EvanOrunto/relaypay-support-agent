    {
      "id": "node-09",
      "name": "Confidence Evaluator",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1440,
        560
      ],
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst question = item.question.toLowerCase();\nconst SENSITIVE = [\"dispute\",\"fraud\",\"legal\",\"suspend\",\"compliance violation\",\"stolen\",\"chargeback\",\"unauthorized\",\"account blocked\",\"refund\"];\nlet keyword_matched = null;\nfor (const kw of SENSITIVE) { if (question.includes(kw)) { keyword_matched = kw; break; } }\nif (keyword_matched) {\n  return [{ json: { confidence: \"escalated\", keyword_matched, question: item.question, session_id: item.session_id, customer_id: item.customer_id, vague: false } }];\n}\nconst wordCount = item.question.trim().split(/\\s+/).filter(w => w.length > 0).length;\nif (wordCount < 4) {\n  return [{ json: { confidence: \"low\", keyword_matched: null, vague: true, question: item.question, session_id: item.session_id, customer_id: item.customer_id } }];\n}\nreturn [{ json: { confidence: \"high\", keyword_matched: null, vague: false, question: item.question, session_id: item.session_id, customer_id: item.customer_id } }];"
      }
    },
